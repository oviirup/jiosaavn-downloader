{
  "name": "jiosaavn-downloader",
  "version": "3.0.3",
  "displayName": "JioSaavn Downloader",
  "description": "An all in one extension for JioSaavn to enable dark mode, download songs, block ads, and more",
  "homepage": "https://github.com/oviirup/jiosaavn-downloader",
  "author": "Avirup Ghosh (https://github.com/oviirup)",
  "license": "MIT",
  "scripts": {
    "build": "run-s 'build:*'",
    "build:chrome": "plasmo build --target=chrome-mv3",
    "build:firefox": "plasmo build --target=firefox-mv2",
    "clean": "npx rimraf .plasmo build",
    "dev:chrome": "plasmo dev --target=chrome-mv3",
    "dev:firefox": "plasmo dev --target=firefox-mv2",
    "format": "prettier . -wu --cache",
    "pack": "run-p 'build:* -- --zip'"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "browser-id3-writer": "^6.3.1",
    "class-variance-authority": "^0.7.1",
    "jszip": "^3.10.1",
    "node-forge": "^1.4.0",
    "p-limit": "^6.2.0",
    "plasmo": "^0.90.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "selector-observer": "^2.1.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/chrome": "^0.0.317",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.9",
    "prettier": "^3.8.1",
    "prettier-plugin-imports": "^4.3.3",
    "prettier-plugin-jsdoc": "^1.8.0",
    "prettier-plugin-pkg": "^0.19.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.19",
    "tailwindcss-pluggables": "^1.2.0",
    "typescript": "^5.9.3"
  },
  "manifest": {
    "permissions": [
      "storage",
      "declarativeNetRequest"
    ],
    "host_permissions": [
      "https://*/*"
    ]
  }
}
